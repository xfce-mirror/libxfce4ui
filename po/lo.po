#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:37
msgid "Window operations menu"
msgstr "ເມນູການຈັດການໜ້າຕ່າງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:38
msgid "Up"
msgstr "ຂຶ້ນ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:39
msgid "Down"
msgstr "ລົງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:40
msgid "Left"
msgstr "ຊ້າຍ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:41
msgid "Right"
msgstr "ຂວາ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:43
msgid "Cycle windows"
msgstr "ວົນຮອບໜ້າຕ່າງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:44
msgid "Cycle windows (Reverse)"
msgstr "ວົນຮອບໜ້າຕ່າງ (ຍ້ອນກັບ)"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:45
msgid "Switch window for same application"
msgstr "ສະຫຼັບໜ້າຕ່າງໃນແອັບພລິເຄຊັນດຽວກັນ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:46
msgid "Switch application"
msgstr "ສະຫຼັບແອັບພລິເຄຊັນ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:47
msgid "Close window"
msgstr "ປິດໜ້າຕ່າງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:48
msgid "Maximize window horizontally"
msgstr "ຂະຫຍາຍໜ້າຕ່າງເຕັມລວງນອນ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:49
msgid "Maximize window vertically"
msgstr "ຂະຫຍາຍໜ້າຕ່າງເຕັມລວງຕັ້ງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:50
msgid "Maximize window"
msgstr "ຂະຫຍາຍໜ້າຕ່າງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:51
msgid "Hide window"
msgstr "ເຊື່ອງໜ້າຕ່າງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:52
msgid "Move window"
msgstr "ຍ້າຍໜ້າຕ່າງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:53
msgid "Resize window"
msgstr "ປັບຂະໜາດໜ້າຕ່າງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:54
msgid "Shade window"
msgstr "ມ້ວນໜ້າຕ່າງຂຶ້ນ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:55
msgid "Stick window"
msgstr "ຕິດໜ້າຕ່າງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:56
msgid "Raise window"
msgstr "ເອົາໜ້າຕ່າງຂຶ້ນໜ້າ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:57
msgid "Lower window"
msgstr "ເອົາໜ້າຕ່າງລົງຫຼັງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:58
msgid "Raise or lower window"
msgstr "ເອົາໜ້າຕ່າງຂຶ້ນ ຫຼື ລົງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:59
msgid "Fill window"
msgstr "ຂະຫຍາຍເຕັມພື້ນທີ່"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:60
msgid "Fill window horizontally"
msgstr "ຂະຫຍາຍເຕັມລວງນອນ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:61
msgid "Fill window vertically"
msgstr "ຂະຫຍາຍເຕັມລວງຕັ້ງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:62
msgid "Toggle above"
msgstr "ສະຫຼັບໄວ້ທາງເທິງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:63
msgid "Toggle fullscreen"
msgstr "ສະຫຼັບເຕັມຈໍ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:64
msgid "Move window to lower monitor"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍລຸ່ມ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:65
msgid "Move window to left monitor"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍຊ້າຍ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:66
msgid "Move window to right monitor"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍຂວາ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:67
msgid "Move window to upper monitor"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍເທິງ"

#: libxfce4kbd-private/xfce-shortcuts-xfwm4.c:68
