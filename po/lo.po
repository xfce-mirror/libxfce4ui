#: ../libxfce4ui/xfce-dialogs.c:110
msgid "Failed to open web browser for online documentation"
msgstr "ບໍ່ສາມາດເປີດເວັບບຣາວເຊີເພື່ອເບິ່ງເອກະສານອອນລາຍໄດ້"

#: ../libxfce4ui/xfce-dialogs.c:265
#, c-format
msgid "Do you want to read the %s manual online?"
msgstr "ທ່ານຕ້ອງການອ່ານຄູ່ມືຂອງ %s ແບບອອນລາຍບໍ່?"

#: ../libxfce4ui/xfce-dialogs.c:267
msgid "Do you want to read the manual online?"
msgstr "ທ່ານຕ້ອງການອ່ານຄູ່ມືແບບອອນລາຍບໍ່?"

#: ../libxfce4ui/xfce-dialogs.c:273
msgid ""
"You will be redirected to the documentation website where the help pages are"
" maintained and translated."
msgstr ""
"ທ່ານຈະຖືກສົ່ງໄປຫາເວັບໄຊເອກະສານ ເຊິ່ງເປັນບ່ອນທີ່ໜ້າຊ່ວຍເຫຼືອຖືກເບິ່ງແຍງ ແລະ "
"ແແປພາສາ."

#. Create cancel button
#: ../libxfce4ui/xfce-dialogs.c:275 ../libxfce4ui/xfce-dialogs.c:533
#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:256
msgid "_Cancel"
msgstr "_ຍົກເລີກ"

#: ../libxfce4ui/xfce-dialogs.c:277
msgid "_Read Online"
msgstr "_ອ່ານອອນລາຍ"

#: ../libxfce4ui/xfce-dialogs.c:286
msgid "_Always go directly to the online documentation"
msgstr "_ໄປຫາເອກະສານອອນລາຍໂດຍກົງສະເໝີ"

#: ../libxfce4ui/xfce-dialogs.c:335 ../libxfce4ui/xfce-dialogs.c:370
#: ../libxfce4ui/xfce-dialogs.c:406
msgid "Close"
msgstr "ປິດ"

#: ../libxfce4ui/xfce-dialogs.c:453
msgid "No"
msgstr "ບໍ່"

#: ../libxfce4ui/xfce-dialogs.c:455
msgid "Yes"
msgstr "ແມ່ນ"

#: ../libxfce4ui/xfce-dialogs.c:459
#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:41
msgid "Cancel"
msgstr "ຍົກເລີກ"

#: ../libxfce4ui/xfce-dialogs.c:518
msgid "Close window with multiple tabs?"
msgstr "ປິດໜ້າຕ່າງທີ່ມີຫຼາຍແຖບບໍ່?"

#: ../libxfce4ui/xfce-dialogs.c:520
msgid ""
"This window has multiple tabs open. Closing this window will also close all "
"its tabs."
msgstr ""
"ໜ້າຕ່າງນີ້ມີຫຼາຍແຖບທີ່ເປີດຢູ່. ການປິດໜ້າຕ່າງນີ້ຈະເຮັດໃຫ້ແຖບທັງໝົດຖືກປິດໄປນຳ."

#: ../libxfce4ui/xfce-dialogs.c:523
#, c-format
msgid ""
"This window has %d tabs open. Closing this window will also close all its "
"tabs."
msgstr ""
"ໜ້າຕ່າງນີ້ມີ %d ແຖບທີ່ເປີດຢູ່. ການປິດໜ້າຕ່າງນີ້ຈະເຮັດໃຫ້ແຖບທັງໝົດຖືກປິດໄປນຳ."

#: ../libxfce4ui/xfce-dialogs.c:529
msgid "Warning"
msgstr "ຄຳເຕືອນ"

#: ../libxfce4ui/xfce-dialogs.c:534
msgid "Close T_ab"
msgstr "ປິດແ_ຖບ"

#: ../libxfce4ui/xfce-dialogs.c:535
msgid "Close _Window"
msgstr "ປິດ_ໜ້າຕ່າງ"

#: ../libxfce4ui/xfce-dialogs.c:540
msgid "Do _not ask me again"
msgstr "_ບໍ່ຕ້ອງຖາມຂ້ອຍອີກ"

#: ../libxfce4ui/xfce-sm-client.c:1427
msgid "Session management client ID"
msgstr "ໄອດີໄຄລເອັນການຈັດການວາລະ"

#: ../libxfce4ui/xfce-sm-client.c:1427
msgid "ID"
msgstr "ໄອດີ"

#: ../libxfce4ui/xfce-sm-client.c:1428
msgid "Disable session management"
msgstr "ປິດການຈັດການວາລະ"

#: ../libxfce4ui/xfce-sm-client.c:1438
msgid "Session management options"
msgstr "ຕົວເລືອກການຈັດການວາລະ"

#: ../libxfce4ui/xfce-sm-client.c:1439
msgid "Show session management options"
msgstr "ສະແດງຕົວເລືອກການຈັດການວາລະ"

#: ../libxfce4ui/xfce-sm-client.c:1609
#, c-format
msgid "Failed to connect to the session manager: %s"
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບຕົວຈັດການວາລະໄດ້: %s"

#: ../libxfce4ui/xfce-sm-client.c:1615
#, c-format
msgid "Session manager did not return a valid client id"
msgstr "ຕົວຈັດການວາລະບໍ່ໄດ້ສົ່ງຄືນໄອດີໄຄລເອັນທີ່ຖືກຕ້ອງ"

#. print warning for user
#: ../libxfce4ui/xfce-spawn.c:397
#, c-format
msgid ""
"Working directory \"%s\" does not exist. It won't be used when spawning "
"\"%s\"."
msgstr "ບໍ່ມີໂຟນເດີເຮັດວຽກ \"%s\" ຢູ່. ມັນຈະບໍ່ຖືກນໍາໃຊ້ເມື່ອເປີດ \"%s\"."

#. retrieve the error and warning messages
#: ../libxfce4ui/xfce-filename-input.c:232
msgid "Filename is too long"
msgstr "ຊື່ໄຟລ໌ຍາວເກີນໄປ"

#: ../libxfce4ui/xfce-filename-input.c:233
msgid "Directory separator illegal in file name"
msgstr "ເຄື່ອງໝາຍແຍກໂຟນເດີໃຊ້ບໍ່ໄດ້ໃນຊື່ໄຟລ໌"

#: ../libxfce4ui/xfce-filename-input.c:234
msgid "Filenames should not start or end with a space"
msgstr "ຊື່ໄຟລ໌ບໍ່ຄວນເລີ່ມຕົ້ນ ຫຼື ລົງທ້າຍດ້ວຍຍະຫວ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts.c:53
#, c-format
msgid ""
"This shortcut is already being used for the action '%s'. Which action do you"
" want to use?"
msgstr ""
"ຄີລັດນີ້ຖືກໃຊ້ໄປແລ້ວສໍາລັບການກະທຳ '%s'. ທ່ານຕ້ອງການໃຊ້ສໍາລັບການກະທຳໃດ?"

#: ../libxfce4kbd-private/xfce-shortcuts.c:54
#: ../libxfce4kbd-private/xfce-shortcuts.c:57
#: ../libxfce4kbd-private/xfce-shortcuts.c:60
#: ../libxfce4kbd-private/xfce-shortcuts.c:63
#, c-format
msgid "Use '%s'"
msgstr "ໃຊ້ '%s'"

#: ../libxfce4kbd-private/xfce-shortcuts.c:54
#: ../libxfce4kbd-private/xfce-shortcuts.c:57
#: ../libxfce4kbd-private/xfce-shortcuts.c:60
#: ../libxfce4kbd-private/xfce-shortcuts.c:63
#, c-format
msgid "Keep '%s'"
msgstr "ຮັກສາ '%s' ໄວ້"

#: ../libxfce4kbd-private/xfce-shortcuts.c:56
#: ../libxfce4kbd-private/xfce-shortcuts.c:59
#, c-format
msgid ""
"This shortcut is already being used for the command '%s'. Which action do "
"you want to use?"
msgstr ""
"ຄີລັດນີ້ຖືກໃຊ້ໄປແລ້ວສໍາລັບຄໍາສັ່ງ '%s'. ທ່ານຕ້ອງການໃຊ້ສໍາລັບການກະທຳໃດ?"

#: ../libxfce4kbd-private/xfce-shortcuts.c:62
#, c-format
msgid ""
"This shortcut is already being used by the action '%s'. Which action do you "
"want to use?"
msgstr "ຄີລັດນີ້ຖືກໃຊ້ໄປແລ້ວໂດຍການກະທຳ '%s'. ທ່ານຕ້ອງການໃຊ້ສໍາລັບການກະທຳໃດ?"

#. This shortcut already exists in the provider, we don't want it twice
#. Warn the user
#: ../libxfce4kbd-private/xfce-shortcuts.c:113
msgid "Please use another key combination."
msgstr "ກະລຸນາໃຊ້ປຸ່ມປະສົມອື່ນ."

#: ../libxfce4kbd-private/xfce-shortcuts.c:114
#, c-format
msgid "%s already triggers this action."
msgstr "%s ໄດ້ໃຊ້ສໍາລັບການກະທຳນີ້ຢູ່ແລ້ວ."

#: ../libxfce4kbd-private/xfce-shortcuts.c:119
#, c-format
msgid "Conflicting actions for %s"
msgstr "ການກະທຳທີ່ຂັດແຍ້ງກັນສໍາລັບ %s"

#: ../libxfce4kbd-private/xfce-shortcuts.c:181
msgid "This shortcut is already being used for something else."
msgstr "ຄີລັດນີ້ຖືກໃຊ້ສໍາລັບຢ່າງອື່ນຢູ່ແລ້ວ."

#: ../libxfce4kbd-private/xfce-shortcuts-editor-dialog.c:94
#: ../libxfce4kbd-private/xfce-shortcuts-editor-dialog.c:131
msgid "Shortcuts Editor"
msgstr "ຕົວແກ້ໄຂຄີລັດ"

#: ../libxfce4kbd-private/xfce-shortcuts-editor.c:380
msgid "The current shortcut. Click to edit..."
msgstr "ຄີລັດປັດຈຸບັນ. ຄລິກເພື່ອແກ້ໄຂ..."

#: ../libxfce4kbd-private/xfce-shortcuts-editor.c:391
msgid "Clear the shortcut"
msgstr "ລ້າງຄີລັດ"

#: ../libxfce4kbd-private/xfce-shortcuts-editor.c:401
msgid "Restore the default shortcut"
msgstr "ຄືນຄ່າຄີລັດເລີ່ມຕົ້ນ"

#. skip leading slash
#: ../libxfce4kbd-private/xfce-shortcuts-editor.c:473
#: ../libxfce4kbd-private/xfce-shortcuts-editor.c:562
#, c-format
msgid "This keyboard shortcut is currently used by: '%s'"
msgstr "ຄີລັດຄີບອດນີ້ຖືກໃຊ້ໂດຍ: '%s'"

#: ../libxfce4kbd-private/xfce-shortcuts-editor.c:476
#: ../libxfce4kbd-private/xfce-shortcuts-editor.c:565
msgid "Keyboard shortcut already in use"
msgstr "ຄີລັດຄີບອດຖືກໃຊ້ຢູ່ແລ້ວ"

#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:217
msgid "Window Manager Action Shortcut"
msgstr "ຄີລັດການກະທຳຂອງຕົວຈັດການໜ້າຕ່າງ"

#. TRANSLATORS: this string will be used to create an explanation for
#. * the user in a following string
#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:220
#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:236
msgid "action"
msgstr "ການກະທຳ"

#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:225
msgid "Command Shortcut"
msgstr "ຄີລັດຄໍາສັ່ງ"

#. TRANSLATORS: this string will be used to create an explanation for
#. * the user in a following string
#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:228
msgid "command"
msgstr "ຄໍາສັ່ງ"

#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:233
msgid "Shortcut"
msgstr "ຄີລັດ"

#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:250
msgid "Clear"
msgstr "ລ້າງ"

#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:273
#, c-format
msgid "Press keyboard keys to trigger the %s '%s'."
msgstr "ກົດປຸ່ມຄີບອດເພື່ອໃຊ້ງານ %s '%s'."

#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:295
msgid "Please press a key"
msgstr "ກະລຸນາກົດປຸ່ມ"

#: ../libxfce4kbd-private/xfce-shortcut-dialog.c:350
msgid "Could not grab the keyboard."
msgstr "ບໍ່ສາມາດຄວບຄຸມຄີບອດໄດ້."

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:36
msgid "Window operations menu"
msgstr "ເມນູການຈັດການໜ້າຕ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:37
msgid "Up"
msgstr "ຂຶ້ນ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:38
msgid "Down"
msgstr "ລົງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:39
msgid "Left"
msgstr "ຊ້າຍ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:40
msgid "Right"
msgstr "ຂວາ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:42
msgid "Cycle windows"
msgstr "ວົນຮອບໜ້າຕ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:43
msgid "Cycle windows (Reverse)"
msgstr "ວົນຮອບໜ້າຕ່າງ (ຍ້ອນກັບ)"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:44
msgid "Switch window for same application"
msgstr "ສະຫຼັບໜ້າຕ່າງໃນແອັບພລິເຄຊັນດຽວກັນ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:45
msgid "Switch application"
msgstr "ສະຫຼັບແອັບພລິເຄຊັນ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:46
msgid "Close window"
msgstr "ປິດໜ້າຕ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:47
msgid "Maximize window horizontally"
msgstr "ຂະຫຍາຍໜ້າຕ່າງເຕັມລວງນອນ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:48
msgid "Maximize window vertically"
msgstr "ຂະຫຍາຍໜ້າຕ່າງເຕັມລວງຕັ້ງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:49
msgid "Maximize window"
msgstr "ຂະຫຍາຍໜ້າຕ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:50
msgid "Hide window"
msgstr "ເຊື່ອງໜ້າຕ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:51
msgid "Move window"
msgstr "ຍ້າຍໜ້າຕ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:52
msgid "Resize window"
msgstr "ປັບຂະໜາດໜ້າຕ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:53
msgid "Shade window"
msgstr "ມ້ວນໜ້າຕ່າງຂຶ້ນ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:54
msgid "Stick window"
msgstr "ຕິດໜ້າຕ່າງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:55
msgid "Raise window"
msgstr "ເອົາໜ້າຕ່າງຂຶ້ນໜ້າ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:56
msgid "Lower window"
msgstr "ເອົາໜ້າຕ່າງລົງຫຼັງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:57
msgid "Raise or lower window"
msgstr "ເອົາໜ້າຕ່າງຂຶ້ນ ຫຼື ລົງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:58
msgid "Fill window"
msgstr "ຂະຫຍາຍເຕັມພື້ນທີ່"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:59
msgid "Fill window horizontally"
msgstr "ຂະຫຍາຍເຕັມລວງນອນ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:60
msgid "Fill window vertically"
msgstr "ຂະຫຍາຍເຕັມລວງຕັ້ງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:61
msgid "Toggle above"
msgstr "ສະຫຼັບໄວ້ທາງເທິງ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:62
msgid "Toggle fullscreen"
msgstr "ສະຫຼັບເຕັມຈໍ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:63
msgid "Move window to lower monitor"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍລຸ່ມ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:64
msgid "Move window to left monitor"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍຊ້າຍ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:65
msgid "Move window to right monitor"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍຂວາ"

#: ../libxfce4kbd-private/xfce-shortcuts-xfwm4.c:66
msgid "Move window to upper monitor"
msgstr "ຍ້າຍໜ້າຕ່າງໄປຈໍເທິງ"

