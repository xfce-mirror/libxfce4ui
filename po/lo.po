#: xfce4-about/main.c:174
msgid "GPUs"
msgstr "ຈີພີຢູ (GPUs)"

#: xfce4-about/main.c:191
msgid "Window Manager"
msgstr "ຕົວຈັດການໜ້າຕ່າງ"

#: xfce4-about/main.c:192
msgid "Handles the placement of windows on the screen."
msgstr "ຈັດການການວາງໜ້າຕ່າງເທິງໜ້າຈໍ."

#: xfce4-about/main.c:195
msgid "Panel"
msgstr "ແຜງ"

#: xfce4-about/main.c:196
msgid "Provides a home for window buttons, launchers, app menu and more."
msgstr "ສະໜອງບ່ອນວາງປຸ່ມໜ້າຕ່າງ, ຕົວເປີດໂປຣແກຣມ, ເມນູແອັບ ແລະ ອື່ນໆ."

#: xfce4-about/main.c:199
msgid "Desktop Manager"
msgstr "ຕົວຈັດການເດັສທັອບ"

#: xfce4-about/main.c:200
msgid "Sets desktop backgrounds, handles icons and more."
msgstr "ຕັ້ງຄ່າພື້ນຫຼັງເດັສທັອບ, ຈັດການໄອຄອນ ແລະ ອື່ນໆ."

#: xfce4-about/main.c:203
msgid "File Manager"
msgstr "ຕົວຈັດການໄຟລ໌"

#: xfce4-about/main.c:204
msgid "Manages your files in a modern, easy-to-use and fast way."
msgstr "ຈັດການໄຟລ໌ຂອງທ່ານໃນຮູບແບບທີ່ທັນສະໄໝ, ໃຊ້ງ່າຍ ແລະ ໄວ."

#: xfce4-about/main.c:207
msgid "Volume Manager"
msgstr "ຕົວຈັດການຄວາມຈຳ"

#: xfce4-about/main.c:208
msgid "Manages removable drives and media for Thunar."
msgstr "ຈັດການໄດຣຟ໌ ແລະ ສື່ທີ່ຖອດອອກໄດ້ສໍາລັບ Thunar."

#: xfce4-about/main.c:211
msgid "Session Manager"
msgstr "ຕົວຈັດການວາລະ"

#: xfce4-about/main.c:212
msgid ""
"Saves and restores your session, handles startup, autostart and shutdown."
msgstr ""
"ບັນທຶກ ແລະ ກູ້ຄືນວາລະຂອງທ່ານ, ຈັດການການເລີ່ມຕົ້ນ, ການເປີດອັດຕະໂນມັດ ແລະ "
"ການປິດລະບົບ."

#: xfce4-about/main.c:215
msgid "Settings Manager"
msgstr "ຕົວຈັດການການຕັ້ງຄ່າ"

#: xfce4-about/main.c:216
msgid "Configures appearance, display, keyboard and mouse settings."
msgstr "ຕັ້ງຄ່າຮູບລັກສະນະ, ການສະແດງຜົນ, ຄີບອດ ແລະ ເມົາສ໌."

#: xfce4-about/main.c:219
msgid "Application Finder"
msgstr "ຕົວຄົ້ນຫາແອັບພລິເຄຊັນ"

#: xfce4-about/main.c:220
msgid "Quickly finds and launches applications installed on your system."
msgstr "ຄົ້ນຫາ ແລະ ເປີດແອັບພລິເຄຊັນທີ່ຕິດຕັ້ງໃນລະບົບຂອງທ່ານຢ່າງວ່ອງໄວ."

#: xfce4-about/main.c:223
msgid "Settings Daemon"
msgstr "ດີມອນການຕັ້ງຄ່າ"

#: xfce4-about/main.c:224
msgid "Stores your settings in a D-Bus-based configuration system."
msgstr "ເກັບການຕັ້ງຄ່າຂອງທ່ານໄວ້ໃນລະບົບການຕັ້ງຄ່າທີ່ໃຊ້ D-Bus."

#: xfce4-about/main.c:227
msgid "A Menu Library"
msgstr "ໄລບຣາຣີເມນູ"

#: xfce4-about/main.c:228
msgid "Implements a freedesktop.org compliant menu based on GLib and GIO."
msgstr "ເຮັດວຽກຕາມມາດຕະຖານເມນູຂອງ freedesktop.org ໂດຍອີງໃສ່ GLib ແລະ GIO."

#: xfce4-about/main.c:231
msgid "Thumbnails Service"
msgstr "ບໍລິການຮູບຕົວຢ່າງ"

#: xfce4-about/main.c:232
msgid "Implements the thumbnail management D-Bus specification."
msgstr "ເຮັດວຽກຕາມຂໍ້ກຳນົດ D-Bus ສໍາລັບການຈັດການຮູບຕົວຢ່າງ."

#: xfce4-about/main.c:285
msgid "Please see <https://www.xfce.org/about/credits>"
msgstr "ກະລຸນາເບິ່ງທີ່ <https://www.xfce.org/about/credits>"

#: xfce4-about/main.c:339
msgid ""
"If you know of anyone missing from this list; don't hesitate and file a bug "
"on <https://gitlab.xfce.org/xfce/libxfce4ui/-/issues> ."
msgstr ""
"ຖ້າທ່ານຮູ້ວ່າໃຜທີ່ຕົກຫຼົ່ນຈາກລາຍຊື່ນີ້; ຢ່າລັງເລທີ່ຈະແຈ້ງບັນຫາໄດ້ທີ່ "
"<https://gitlab.xfce.org/xfce/libxfce4ui/-/issues> ."

#: xfce4-about/main.c:344
msgid "Thanks to all who helped making this software available!"
msgstr "ຂອບໃຈທຸກຄົນທີ່ຊ່ວຍເຮັດໃຫ້ຊອບແວນີ້ພ້ອມໃຊ້ງານ!"

