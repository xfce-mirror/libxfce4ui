#: xfce-open/main.c:218
msgid "Usage: xfce-open [URLs...]"
msgstr "ການນໍາໃຊ້: xfce-open [URLs...]"

#: xfce-open/main.c:219
msgid "       xfce-open --launch TYPE [PARAMETERs...]"
msgstr "       xfce-open --launch ປະເພດ [ພາລາມິເຕີ...]"

#: xfce-open/main.c:221
msgid "  -?, --help                          Print this help message and exit"
msgstr "  -?, --help                          ສະແດງຂໍ້ຄວາມຊ່ວຍເຫຼືອນີ້ ແລະ ອອກ"

#: xfce-open/main.c:222
msgid ""
"  -V, --version                       Print version information and exit"
msgstr "  -V, --version                       ສະແດງຂໍ້ມູນເວີຊັນ ແລະ ອອກ"

#: xfce-open/main.c:224
msgid ""
"  --launch TYPE [PARAMETERs...]       Launch the preferred application of\n"
"                                      TYPE with the optional PARAMETERs, where\n"
"                                      TYPE is one of the following values."
msgstr "  --launch ປະເພດ [ພາລາມິເຕີ...]       ເປີດແອັບພລິເຄຊັນທີ່ຕ້ອງການຂອງ\n                                      ປະເພດ ນັ້ນພ້ອມກັບພາລາມິເຕີເສີມ, ໂດຍທີ່\n                                      ປະເພດ ແມ່ນໜຶ່ງໃນຄ່າຕໍ່ໄປນີ້."

#: xfce-open/main.c:228
msgid ""
"  --working-directory DIRECTORY       Default working directory for applications\n"
"                                      when using the --launch option."
msgstr "  --working-directory ໂຟນເດີ           ໂຟນເດີເຮັດວຽກເລີ່ມຕົ້ນສໍາລັບແອັບພລິເຄຊັນ\n                                      ເມື່ອໃຊ້ຕົວເລືອກ --launch."

#: xfce-open/main.c:231
msgid "The following TYPEs are supported for the --launch command:"
msgstr "ປະເພດ (TYPE) ຕໍ່ໄປນີ້ແມ່ນຮອງຮັບສໍາລັບຄຳສັ່ງ --launch:"

#. Note to Translators: Do not translate the TYPEs (WebBrowser, MailReader,
#. TerminalEmulator),
#. * since the xfce4-mime-helper utility will not accept localized TYPEs.
#: xfce-open/main.c:237
msgid ""
"  WebBrowser       - The preferred Web Browser.\n"
"  MailReader       - The preferred Mail Reader.\n"
"  FileManager      - The preferred File Manager.\n"
"  TerminalEmulator - The preferred Terminal Emulator.\n"
"  TextEditor       - The preferred Text Editor.\n"
"  ImageViewer      - The preferred Image Viewer.\n"
"  AudioPlayer      - The preferred Audio Player.\n"
"  VideoPlayer      - The preferred Video Player."
msgstr "  WebBrowser       - ເວັບບຣາວເຊີທີ່ຕ້ອງການ.\n  MailReader       - ຕົວອ່ານເມລທີ່ຕ້ອງການ.\n  FileManager      - ຕົວຈັດການໄຟລ໌ທີ່ຕ້ອງການ.\n  TerminalEmulator - ຕົວຈຳລອງເທີມີນໍລທີ່ຕ້ອງການ.\n  TextEditor       - ຕົວແກ້ໄຂຂໍ້ຄວາມທີ່ຕ້ອງການ.\n  ImageViewer      - ຕົວເບິ່ງຮູບພາບທີ່ຕ້ອງການ.\n  AudioPlayer      - ຕົວຫຼິ້ນສຽງທີ່ຕ້ອງການ.\n  VideoPlayer      - ຕົວຫຼິ້ນວິດີໂອທີ່ຕ້ອງການ."

#: xfce-open/main.c:247
msgid ""
"If you don't specify the --launch option, xfce-open will open all specified\n"
"URLs with their preferred URL handlers. Else, if you specify the --launch\n"
"option, you can select which preferred application you want to run, and\n"
"pass additional parameters to the application (i.e. for TerminalEmulator\n"
"you can pass the command line that should be run in the terminal)."
msgstr "ຖ້າທ່ານບໍ່ລະບຸຕົວເລືອກ --launch, xfce-open ຈະເປີດທຸກ URLs ທີ່ລະບຸ\nດ້ວຍຕົວຈັດການ URL ທີ່ກ່ຽວຂ້ອງ. ແຕ່ຖ້າທ່ານລະບຸຕົວເລືອກ --launch,\nທ່ານສາມາດເລືອກແອັບພລິເຄຊັນທີ່ຕ້ອງການຮັນ ແລະ ສົ່ງພາລາມິເຕີເພີ່ມເຕີມ\nໃຫ້ກັບແອັບພລິເຄຊັນ (ເຊັ່ນ: ສໍາລັບ TerminalEmulator ທ່ານສາມາດສົ່ງຄຳສັ່ງ\nທີ່ຈະໃຫ້ຮັນໃນເທີມີນໍລໄດ້)."

#: xfce-open/main.c:422
#, c-format
msgid "Failed to launch preferred application for category \"%s\"."
msgstr "ເປີດແອັບພລິເຄຊັນທີ່ຕ້ອງການສໍາລັບໝວດໝູ່ \"%s\" ບໍ່ສໍາເລັດ."

#: xfce-open/main.c:713
#, c-format
msgid "Unable to detect the URI-scheme of \"%s\"."
msgstr "ບໍ່ສາມາດກວດສອບ URI-scheme ຂອງ \"%s\" ໄດ້."

#: xfce-open/main.c:727
msgid "Failed to open URI."
msgstr "ເປີດ URI ບໍ່ສໍາເລັດ."
