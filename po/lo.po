#: libxfce4ui/xfce-dialogs.c:109
msgid "Failed to open web browser for online documentation"
msgstr "ບໍ່ສາມາດເປີດເວັບບຣາວເຊີເພື່ອເບິ່ງເອກະສານອອນລາຍໄດ້"

#: libxfce4ui/xfce-dialogs.c:265
#, c-format
msgid "Do you want to read the %s manual online?"
msgstr "ທ່ານຕ້ອງການອ່ານຄູ່ມືຂອງ %s ແບບອອນລາຍບໍ່?"

#: libxfce4ui/xfce-dialogs.c:267
msgid "Do you want to read the manual online?"
msgstr "ທ່ານຕ້ອງການອ່ານຄູ່ມືແບບອອນລາຍບໍ່?"

#: libxfce4ui/xfce-dialogs.c:269
msgid ""
"You will be redirected to the documentation website where the help pages are"
" maintained and translated."
msgstr ""
"ທ່ານຈະຖືກສົ່ງໄປຫາເວັບໄຊເອກະສານ ເຊິ່ງເປັນບ່ອນທີ່ໜ້າຊ່ວຍເຫຼືອຖືກເບິ່ງແຍງ ແລະ "
"ແປພາສາ."

#: libxfce4ui/xfce-dialogs.c:271
msgid "Read the manual"
msgstr "ອ່ານຄູ່ມື"

