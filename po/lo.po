#: libxfce4ui/xfce-dialogs.c:332 libxfce4ui/xfce-dialogs.c:367
#: libxfce4ui/xfce-dialogs.c:403
msgid "Close"
msgstr "ປິດ"

#: libxfce4ui/xfce-dialogs.c:450
msgid "No"
msgstr "ບໍ່"

#: libxfce4ui/xfce-dialogs.c:452
msgid "Yes"
msgstr "ແມ່ນ"

#: libxfce4ui/xfce-dialogs.c:456 libxfce4kbd-private/xfce-shortcuts-xfwm4.c:42
msgid "Cancel"
msgstr "ຍົກເລີກ"

#: libxfce4ui/xfce-dialogs.c:515
msgid "Close window with multiple tabs?"
msgstr "ປິດໜ້າຕ່າງທີ່ມີຫຼາຍແຖບບໍ່?"

#: libxfce4ui/xfce-dialogs.c:517
msgid ""
"This window has multiple tabs open. Closing this window will also close all "
"its tabs."
msgstr ""
"ໜ້າຕ່າງນີ້ມີຫຼາຍແຖບທີ່ເປີດຢູ່. ການປິດໜ້າຕ່າງນີ້ຈະເຮັດໃຫ້ແຖບທັງໝົດຖືກປິດໄປນຳ."

#: libxfce4ui/xfce-dialogs.c:520
#, c-format
msgid ""
"This window has %d tabs open. Closing this window will also close all its "
"tabs."
msgstr ""
"ໜ້າຕ່າງນີ້ມີ %d ແຖບທີ່ເປີດຢູ່. ການປິດໜ້າຕ່າງນີ້ຈະເຮັດໃຫ້ແຖບທັງໝົດຖືກປິດໄປນຳ."

#: libxfce4ui/xfce-dialogs.c:527
msgid "Warning"
msgstr "ຄຳເຕືອນ"

#: libxfce4ui/xfce-dialogs.c:532
msgid "Close T_ab"
msgstr "ປິດແ_ຖບ"

#: libxfce4ui/xfce-dialogs.c:533
msgid "Close _Window"
msgstr "ປິດ_ໜ້າຕ່າງ"

#: libxfce4ui/xfce-dialogs.c:538
msgid "Do _not ask me again"
msgstr "_ບໍ່ຕ້ອງຖາມຂ້ອຍອີກ"

#: libxfce4ui/xfce-sm-client.c:1507
msgid "Session management client ID"
msgstr "ໄອດີໄຄລເອັນການຈັດການວາລະ"

#: libxfce4ui/xfce-sm-client.c:1507
msgid "ID"
msgstr "ໄອດີ"

#: libxfce4ui/xfce-sm-client.c:1508
msgid "Disable session management"
msgstr "ປິດການຈັດການວາລະ"

#: libxfce4ui/xfce-sm-client.c:1518
msgid "Session management options"
msgstr "ຕົວເລືອກການຈັດການວາລະ"

#: libxfce4ui/xfce-sm-client.c:1518
msgid "Show session management options"
msgstr "ສະແດງຕົວເລືອກການຈັດການວາລະ"

#: libxfce4ui/xfce-sm-client.c:1692
#, c-format
msgid "Failed to connect to the session manager: %s"
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບຕົວຈັດການວາລະໄດ້: %s"

#: libxfce4ui/xfce-sm-client.c:1701
msgid "Session manager did not return a valid client id"
msgstr "ຕົວຈັດການວາລະບໍ່ໄດ້ສົ່ງຄືນໄອດີໄຄລເອັນທີ່ຖືກຕ້ອງ"

#. print warning for user
#: libxfce4ui/xfce-spawn.c:387
#, c-format
msgid ""
"Working directory \"%s\" does not exist. It won't be used when spawning "
"\"%s\"."
msgstr "ບໍ່ມີໂຟນເດີເຮັດວຽກ \"%s\" ຢູ່. ມັນຈະບໍ່ຖືກນໍາໃຊ້ເມື່ອເປີດ \"%s\"."

#. retrieve the error and warning messages
#: libxfce4ui/xfce-filename-input.c:238
msgid "Filename is too long"
msgstr "ຊື່ໄຟລ໌ຍາວເກີນໄປ"

#: libxfce4ui/xfce-filename-input.c:239
msgid "Directory separator illegal in file name"
msgstr "ເຄື່ອງໝາຍແຍກໂຟນເດີໃຊ້ບໍ່ໄດ້ໃນຊື່ໄຟລ໌"

#: libxfce4ui/xfce-filename-input.c:240
msgid "Filenames should not start or end with a space"
msgstr "ຊື່ໄຟລ໌ບໍ່ຄວນເລີ່ມຕົ້ນ ຫຼື ລົງທ້າຍດ້ວຍຍະຫວ່າງ"

#: libxfce4kbd-private/xfce-shortcuts.c:47
#, c-format
msgid ""
"This shortcut is already being used for the action '%s'. Which action do you"
" want to use?"
msgstr ""
"ຄີລັດນີ້ຖືກໃຊ້ໄປແລ້ວສໍາລັບການກະທຳ '%s'. ທ່ານຕ້ອງການໃຊ້ສໍາລັບການກະທຳໃດ?"

#: libxfce4kbd-private/xfce-shortcuts.c:48
#: libxfce4kbd-private/xfce-shortcuts.c:51
#: libxfce4kbd-private/xfce-shortcuts.c:54
#: libxfce4kbd-private/xfce-shortcuts.c:57
#, c-format
msgid "Use '%s'"
msgstr "ໃຊ້ '%s'"

#: libxfce4kbd-private/xfce-shortcuts.c:48
#: libxfce4kbd-private/xfce-shortcuts.c:51
#: libxfce4kbd-private/xfce-shortcuts.c:54
#: libxfce4kbd-private/xfce-shortcuts.c:57
#, c-format
msgid "Keep '%s'"
msgstr "ຮັກສາ '%s' ໄວ້"

#: libxfce4kbd-private/xfce-shortcuts.c:50
#: libxfce4kbd-private/xfce-shortcuts.c:53
#, c-format
msgid ""
"This shortcut is already being used for the command '%s'. Which action do "
"you want to use?"
msgstr ""
"ຄີລັດນີ້ຖືກໃຊ້ໄປແລ້ວສໍາລັບຄໍາສັ່ງ '%s'. ທ່ານຕ້ອງການໃຊ້ສໍາລັບການກະທຳໃດ?"

#: libxfce4kbd-private/xfce-shortcuts.c:56
#, c-format
msgid ""
"This shortcut is already being used by the action '%s'. Which action do you "
"want to use?"
msgstr "ຄີລັດນີ້ຖືກໃຊ້ໄປແລ້ວໂດຍການກະທຳ '%s'. ທ່ານຕ້ອງການໃຊ້ສໍາລັບການກະທຳໃດ?"

#: libxfce4kbd-private/xfce-shortcuts.c:108
msgid "Please use another key combination."
msgstr "ກະລຸນາໃຊ້ປຸ່ມປະສົມອື່ນ."

#: libxfce4kbd-private/xfce-shortcuts.c:108
#, c-format
msgid "%s already triggers this action."
msgstr "%s ໄດ້ໃຊ້ສໍາລັບການກະທຳນີ້ຢູ່ແລ້ວ."

#: libxfce4kbd-private/xfce-shortcuts.c:113
#, c-format
msgid "Conflicting actions for %s"
msgstr "ການກະທຳທີ່ຂັດແຍ້ງກັນສໍາລັບ %s"

#: libxfce4kbd-private/xfce-shortcuts.c:173
msgid "This shortcut is already being used for something else."
msgstr "ຄີລັດນີ້ຖືກໃຊ້ສໍາລັບຢ່າງອື່ນຢູ່ແລ້ວ."

#: libxfce4kbd-private/xfce-shortcuts-editor-dialog.c:91
#: libxfce4kbd-private/xfce-shortcuts-editor-dialog.c:128
msgid "Shortcuts Editor"
msgstr "ຕົວແກ້ໄຂຄີລັດ"

#: libxfce4kbd-private/xfce-shortcuts-editor.c:493
msgid "The current shortcut. Click to edit..."
msgstr "ຄີລັດປັດຈຸບັນ. ຄລິກເພື່ອແກ້ໄຂ..."

#: libxfce4kbd-private/xfce-shortcuts-editor.c:505
msgid "Clear the shortcut"
msgstr "ລ້າງຄີລັດ"

#: libxfce4kbd-private/xfce-shortcuts-editor.c:517
msgid "Restore the default shortcut"
msgstr "ຄືນຄ່າຄີລັດເລີ່ມຕົ້ນ"

#. skip leading slash
